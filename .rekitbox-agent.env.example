# Copy to .rekitbox-agent.env (ignored) and source before running scripts/agent_workflow.sh

# Provider mode:
#   ollama -> local/offline-first
#   openai -> internet mode with optional free-tier provider via OPENAI_BASE_URL
export REKIT_AGENT_PROVIDER=ollama
export REKIT_AGENT_MODEL=qwen2.5-coder:7b

# Prompt profile (default|cl|is|reviewpr)
export REKIT_AGENT_PROFILE=cl

# Optional custom Ollama endpoint
export REKIT_OLLAMA_URL=http://127.0.0.1:11434/api/chat

# Optional internet provider mode (OpenAI-compatible API)
# export OPENAI_API_KEY=replace_me
# export OPENAI_BASE_URL=https://api.openai.com/v1

# Safety switches (recommended defaults)
export REKIT_AGENT_AUTO_APPLY=0
export REKIT_AGENT_AUTO_COMMIT=0
export REKIT_AGENT_AUTO_PUSH=0
export REKIT_AGENT_SYNC_PUBLIC=0

# Optional tuning
export REKIT_AGENT_INTERVAL=180
