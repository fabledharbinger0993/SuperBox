.vercel
.env*.local

# ── Home directory protection ──────────────────────────────────────────────
# The SuperBox git repo is rooted at ~/ so git sees the entire home directory.
# Everything below is ignored — only FabledHarbinger/ (the actual project) is tracked.

# macOS system folders
.Trash
Library
Applications

# Standard home folders
Desktop
Downloads
Documents
Movies
Music
Pictures
Public

# Dev tools and shell state
.nvm
.npm
.volta
.local
.config
.cache
.vscode
.cursor
.ssh
.zsh_history
.zsh_sessions
.bash_history
.bash_sessions
.DS_Store
.gitconfig

# Other projects that are not SuperBox
holographic-mind
Budget
AIFF MOD.app
Dropbox-Cameronkthedj
Dropbox-ProfessionalDJteam
com.visualstudio.code.tunnel.plist
super_Logo.png

# SuperBox runtime data (generated — not source code)
rekordbox-toolkit

